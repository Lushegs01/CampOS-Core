# Database (Neon PostgreSQL)
# Use the POOLED connection string from Neon for DATABASE_URL
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/campos_core?sslmode=require"
# Use the DIRECT (non-pooled) connection string for migrations
DIRECT_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/campos_core?sslmode=require"

# Redis (Upstash)
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxQ="

# Auth
NEXTAUTH_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET="generate-a-strong-random-secret-here"
JWT_SECRET="generate-a-different-strong-random-secret-here"

# Email (optional — leave empty to start without email features)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
FROM_EMAIL="noreply@campos.io"

# File Storage (Vercel Blob — auto-configured on Vercel, set manually for local dev)
BLOB_READ_WRITE_TOKEN=""
